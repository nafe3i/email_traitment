# .env.example — Environment Variables Template
# 
# INSTRUCTIONS:
# 1. Copier ce fichier: cp .env.example .env
# 2. Remplir chaque variable selon votre environnement
# 3. NE JAMAIS commiter .env (il contient des secrets!)
#
# GÉNÉRATION DE SECRETS:
#   SECRET_KEY (Fernet):
#     python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
#   JWT_SECRET:
#     python -c 'import secrets; print(secrets.token_urlsafe(32))'


# ═══════════════════════════════════════════════════════════════════════════════
# 1️⃣ SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

DEBUG=false
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development


# ═══════════════════════════════════════════════════════════════════════════════
# 2️⃣ OLLAMA CONFIGURATION (AI Models)
# ═══════════════════════════════════════════════════════════════════════════════

# Point de connexion à Ollama
# Local: http://localhost:11434
# Docker: http://ollama:11434
# Remote: https://ollama.yourdomain.com
OLLAMA_BASE=http://localhost:11434

# Timeout pour les appels Ollama (en secondes, 10-300)
OLLAMA_TIMEOUT=60

# Modèle pour embeddings (recommandé: nomic-embed-text)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Modèle LLM pour réponses (recommandé: mistral)
OLLAMA_LLM_MODEL=mistral


# ═══════════════════════════════════════════════════════════════════════════════
# 3️⃣ RAG CONFIGURATION (Retrieval Augmented Generation)
# ═══════════════════════════════════════════════════════════════════════════════

# Nombre de résultats à récupérer de la DB vectorielle
TOP_K=3

# Seuil de confiance minimum pour inclure un résultat (0.0-1.0)
CONFIDENCE_THRESHOLD=0.50


# ═══════════════════════════════════════════════════════════════════════════════
# 4️⃣ DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Chemin vers ChromaDB (vectorial database)
CHROMA_PATH=./data/chroma_db

# Chemin vers le fichier de rapport JSON
REPORT_PATH=./data/reports/report.json

# Chemin vers les sauvegardes
BACKUP_PATH=./data/backups


# ═══════════════════════════════════════════════════════════════════════════════
# 5️⃣ SECURITY CONFIGURATION (🔒 CRITICAL!)
# ═══════════════════════════════════════════════════════════════════════════════

# Master encryption key for Fernet (required!)
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Example: gAAAAABlV2K5_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=
SECRET_KEY=change_me_generate_new_key

# Secret for JWT signing (required!)
# OBLIGATOIRE — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Example: Y3d4aTJYMXQzVXU5cWhqMmg2czBkbzQ2ZzIzUQ==
JWT_SECRET=REMPLACER_PAR_UNE_VALEUR_ALEATOIRE_64_CHARS

# JWT algorithm (HS256 ou RS256)
JWT_ALGORITHM=HS256

# JWT token expiry (heures, 1-720)
JWT_EXPIRY_HOURS=24


# ═══════════════════════════════════════════════════════════════════════════════
# 6️⃣ CORS CONFIGURATION (Cross-Origin Resource Sharing)
# ═══════════════════════════════════════════════════════════════════════════════

# Domaines autorisés (séparés par virgules)
# Development:  http://localhost:3000,http://localhost:8080
# Production:   https://aui.ma,https://www.aui.ma
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173


# ═══════════════════════════════════════════════════════════════════════════════
# 7️⃣ RATE LIMITING CONFIGURATION (Protection DDoS)
# ═══════════════════════════════════════════════════════════════════════════════

# Activer/désactiver le rate limiting
RATE_LIMIT_ENABLED=true

# Limite par endpoint (format: N/period, period=second/minute/hour)
RATE_LIMIT_PER_PROCESS=10/minute

# Stockage du rate limit (memory ou redis)
RATE_LIMIT_STORAGE=memory://


# ═══════════════════════════════════════════════════════════════════════════════
# 8️⃣ LOGGING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Format de log (json ou text)
LOG_FORMAT=json


# ═══════════════════════════════════════════════════════════════════════════════
# 9️⃣ GMAIL CONFIGURATION (Email Integration)
# ═══════════════════════════════════════════════════════════════════════════════

# Chemin vers les credentials Google (JSON téléchargé)
GMAIL_CREDENTIALS_PATH=./credentials/credentials.json

# Chemin vers le token Gmail (auto-généré après première authentification)
GMAIL_TOKEN_PATH=./credentials/token.json


# ═══════════════════════════════════════════════════════════════════════════════
# 🔟 ADMIN SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Domaine autorisé pour l'inscription publique
ALLOWED_REGISTER_DOMAIN=aui.ma

# Email admin par défaut (pour création compte)
ADMIN_EMAIL=admin@aui.ma

# Mot de passe admin initial (à changer après connexion!)
ADMIN_PASSWORD=admin123456


# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️ SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# ✅ DO:
#   - Utiliser variables d'environnement pour tous les secrets
#   - Régénérer SECRET_KEY et JWT_SECRET à chaque déploiement
#   - Garder .env en .gitignore
#   - Utiliser des valeurs différentes par environnement
#
# ❌ DON'T:
#   - Ne jamais commiter .env
#   - Ne jamais hardcoder les secrets dans le code
#   - Ne jamais partager SECRET_KEY ou JWT_SECRET
#   - Ne jamais utiliser les mêmes secrets en dev/prod
#
# ═══════════════════════════════════════════════════════════════════════════════
